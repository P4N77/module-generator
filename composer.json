{
    "name": "sodeker/module-generator",
    "description": "Generador de módulos DDD para el ecosistema Sódeker (Laravel + Inertia/Vue + multi-tenant Suite).",
    "type": "library",
    "license": "proprietary",
    "keywords": ["laravel", "ddd", "generator", "scaffold", "sodeker"],
    "require": {
        "php": "^8.2",
        "illuminate/console": "^11.0|^12.0",
        "illuminate/support": "^11.0|^12.0",
        "illuminate/filesystem": "^11.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "Sodeker\\ModuleGenerator\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Sodeker\\ModuleGenerator\\ModuleGeneratorServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
